# ---- DB ----
POSTGRES_USER=permits
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=permits
# Backup:
PERMITS_BACKUP_S3_URI=s3://your-permits-backups
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_DEFAULT_REGION=eu-central-1

# ---- Backend ----
PERMITS_REPO_URL=https://github.com/gy-mate/permits
PERMITS_CORS_ORIGINS=https://permits.example.com
PERMITS_ENRICH_TIMEOUT=600
PERMITS_WIKIDATA_SPARQL_API_URL=https://qlever.dev/api/wikidata
PERMITS_OSM_SPARQL_API_URL=https://qlever.dev/api/osm-planet

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8000  # Base URL of the backend API as seen by the browser when running locally

# ---- Infra ----
ACME_EMAIL=example@example.com  # Contact email for the Let's Encrypt ACME account
TF_VAR_hcloud_token=xxxxxxxx-your-hetzner-cloud-token
TF_VAR_cloudflare_api_token=your-cloudflare-zone-dns-edit-token
TF_VAR_cloudflare_zone_id=your-website-domain-zone-id
TF_VAR_hostname=api.permits.example.com  # Backend API host. Use a dedicated subdomain so the frontend host (e.g. permits.example.com) stays free
TF_VAR_ssh_public_key="ssh-ed25519 AAAA... you@host"
TF_VAR_k3s_token=change-me-to-a-long-random-secret
# Optional, set after the ingress LoadBalancer exists:
TF_VAR_lb_ipv4=
TF_VAR_lb_ipv6=
