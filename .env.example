# ---- Database ----
POSTGRES_USER=permits
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=permits

# ---- Backend ----
PERMITS_REPO_URL=https://github.com/gy-mate/permits
PERMITS_CORS_ORIGINS=*
PERMITS_ENRICH_TIMEOUT=600

# ---- Frontend ----
# Base URL of the backend API as seen by the browser.
VITE_API_BASE_URL=http://localhost:8000

# ---- Infrastructure (used by envsubst when applying k8s manifests) ----
# Contact email for the Let's Encrypt ACME account.
ACME_EMAIL=example@example.com
